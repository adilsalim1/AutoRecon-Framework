{
  "domain": "example.com",
  "stream_subprocess_output": true,
  "bootstrap": {
    "auto_install": true
  },
  "tools": {
    "subfinder": "subfinder",
    "assetfinder": "assetfinder",
    "amass": "amass",
    "github_subdomains": "github-subdomains",
    "shuffledns": "shuffledns",
    "waybackurls": "waybackurls",
    "gau": "gau",
    "katana": "katana",
    "hakrawler": "hakrawler",
    "httpx": "httpx",
    "nuclei": "nuclei",
    "subjack": "subjack",
    "subzy": "subzy",
    "ffuf": "ffuf",
    "wafw00f": "wafw00f",
    "naabu": "naabu",
    "nmap": "nmap",
    "whatweb": "whatweb",
    "wappalyzer": "wappalyzer",
    "python3": "python3"
  },
  "discovery": {
    "enabled": true,
    "expand_subdomains": true,
    "timeout_seconds": 300,
    "wordlist": "",
    "resolvers": ""
  },
  "collection": {
    "enabled": true,
    "providers": ["gau", "waybackurls", "katana", "hakrawler"],
    "timeout_seconds": 300,
    "max_urls_per_host": 300,
    "max_crawl_seeds": 15
  },
  "scanning": {
    "enabled": true,
    "live_hosts_only": false,
    "parallel_workers": 4,
    "rate_limit_per_second": 10,
    "skip_duplicate_targets": true,
    "timeout_seconds": 300,
    "secretfinder_script": "",
    "wafw00f_aggressive": true,
    "waf_skip_aggressive": false,
    "js_analysis_enabled": true
  },
  "alerts": {
    "webhook_url": "",
    "min_severity": "high",
    "batch_summaries": true,
    "deduplicate": true
  },
  "execution": {
    "mode": "sequential",
    "max_retries": 3,
    "retry_backoff_seconds": 1.0
  },
  "storage": {
    "backend": "json",
    "output_dir": "output"
  },
  "log_level": "INFO",
  "log_json": false
}
