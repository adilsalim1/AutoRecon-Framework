# Copy to `.env` (never commit `.env`). Discord webhook URLs only — no secrets in YAML.
# python-dotenv loads this from the project root or current working directory.

DISCORD_WEBHOOK_VULNERABILITIES=
DISCORD_WEBHOOK_TECH=
DISCORD_WEBHOOK_PORTS=
DISCORD_WEBHOOK_ASSETS=
DISCORD_WEBHOOK_CRITICAL=
DISCORD_WEBHOOK_SECRETS=
DISCORD_WEBHOOK_STAGING=
DISCORD_WEBHOOK_SUMMARY=
