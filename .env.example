# Copy to `.env` (never commit `.env`). Secrets here — not in YAML.
# python-dotenv loads from the project root (AutoRecon-Framework/) and current working directory.

# Fine-grained or classic PAT for github-subdomains discovery (optional; skipped if unset).
GITHUB_TOKEN=

# Each URL can point at a different Discord channel. TECH = WhatWeb / Wappalyzer / httpx tech fingerprints.
DISCORD_WEBHOOK_VULNERABILITIES=
DISCORD_WEBHOOK_TECH=
DISCORD_WEBHOOK_PORTS=
DISCORD_WEBHOOK_ASSETS=
DISCORD_WEBHOOK_CRITICAL=
DISCORD_WEBHOOK_SECRETS=
DISCORD_WEBHOOK_STAGING=
# End-of-run pipeline summary embed; also default target for final export files when broadcast is off.
DISCORD_WEBHOOK_SUMMARY=
